# Archived / purge
ARCHIVED_PURGE_INTERVAL_S=
ARCHIVED_PURGE_GRACE_DAYS=            # Grace before final purge
ORPHAN_SWEEP_INTERVAL_S=              # Orphan-blob sweep cadence

# Anomaly detection (post-backup drop guards)
ANOMALY_MIN_PRIOR_SNAPSHOTS=          # Baseline history needed
ANOMALY_MIN_AVG_ITEMS=                # Skip below this avg item count
ANOMALY_MIN_DELETED_ITEMS=
ANOMALY_DELETION_FRACTION=
ANOMALY_DROP_RATIO=

# ═══════════════════════════════════════════════════════════════════════
# On-prem S3 / S3-compatible storage backend
# ═══════════════════════════════════════════════════════════════════════
ONPREM_S3_ENDPOINT=
ONPREM_S3_REGION=
ONPREM_S3_ACCESS_KEY=
ONPREM_S3_SECRET_KEY=
ONPREM_S3_BUCKETS=                    # Comma list of allowed buckets
ONPREM_S3_VERIFY_TLS=                 # true / false
ONPREM_S3_CA_BUNDLE=                  # Path to CA bundle PEM
ONPREM_MULTIPART_THRESHOLD_MB=
ONPREM_RETRY_MAX=
ONPREM_UPLOAD_CONCURRENCY=

# ═══════════════════════════════════════════════════════════════════════
# Audit / Activity
# ═══════════════════════════════════════════════════════════════════════
AUDIT_POST_TIMEOUT_S=                 # Audit POST hard timeout
AUDIT_EMIT_PARTITION_EVENTS=          # Emit per-partition audit rows
ACTIVITY_GROUP_DEFAULT=               # Default activity grouping

# ═══════════════════════════════════════════════════════════════════════
# Notification email
# ═══════════════════════════════════════════════════════════════════════
NOTIFICATION_EMAIL_ENABLED=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_SMTP_HOST=
NOTIFICATION_EMAIL_SMTP_PORT=
NOTIFICATION_EMAIL_SMTP_USERNAME=
NOTIFICATION_EMAIL_SMTP_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
# Feature toggles / safety
# ═══════════════════════════════════════════════════════════════════════
TOGGLE_CONFIRM_TEXT=                  # Required confirmation phrase on toggle changes
TOGGLE_SMOKE_PASSTHROUGH_REQUIRED=    # Smoke must pass before toggle commits
TOGGLE_SMOKE_PASSTHROUGH_TIMEOUT_S=

# ═══════════════════════════════════════════════════════════════════════
# Bulk-insert / DB tuning
# ═══════════════════════════════════════════════════════════════════════
BULK_INSERT_CHUNK=                    # Rows per INSERT batch

# ═══════════════════════════════════════════════════════════════════════
# Metrics / observability
# ═══════════════════════════════════════════════════════════════════════
CORE_METRICS_PORT=                    # Prometheus exporter port (core services)
SLA_METRICS_PORT=                     # SLA service Prometheus exporter

# ═══════════════════════════════════════════════════════════════════════
# Autoscaler
# ═══════════════════════════════════════════════════════════════════════
AUTOSCALER_CONFIG=                    # JSON / YAML autoscaler ruleset
SCALE_INTERVAL_S=                     # Autoscaler tick
SCALE_HYSTERESIS=                     # Hysteresis fraction (avoid flap)

# ═══════════════════════════════════════════════════════════════════════
# Alembic / migrations
# (These are migration-internal flags set by the deploy automation —
#  rarely needed in a developer .env. Listed for completeness.)
# ═══════════════════════════════════════════════════════════════════════
ALEMBIC_BACKUP_TAKEN=                 # Set after pre-migration pg_dump
ALEMBIC_DISK_HEADROOM_OK=             # Set after disk-headroom check
ALEMBIC_DRAIN_CHECK_SKIP=             # Skip the drain check (DANGEROUS)
ALEMBIC_FORCE_PARTITIONING=           # Force a partitioning migration to run
ALEMBIC_WAL_TUNED=                    # Set after WAL settings tuned

# ═══════════════════════════════════════════════════════════════════════
# Railway runtime (auto-set by Railway; listed so .env doesn't shadow)
# ═══════════════════════════════════════════════════════════════════════
RAILWAY_GIT_COMMIT_SHA=               # Auto-set by Railway
RAILWAY_SERVICE_NAME=                 # Auto-set
RAILWAY_REPLICA_ID=                   # Auto-set
RAILWAY_PROJECT_ID=                   # Auto-set
RAILWAY_ENVIRONMENT_ID=               # Auto-set
RAILWAY_API_TOKEN=                    # Optional: lets the backend call Railway's GraphQL API

# ═══════════════════════════════════════════════════════════════════════
# Partition fanout (snapshot_partitions table — shards per resource
# type so a big mailbox / drive / chat list is drained by N workers in
# parallel and aggregated via PARTITION FINALIZE). Each resource type
# has its own enable/threshold/sizing knobs.
# ═══════════════════════════════════════════════════════════════════════
BACKUP_FANOUT_ENABLED=                # Master switch for bulk fanout publisher
MAX_CONCURRENT_PARTITIONS_PER_TENANT= # Cap on simultaneous partition workers per tenant

# Mail partition (USER_MAIL)
MAIL_PARTITION_ENABLED=
MAIL_PARTITION_MIN_FOLDERS=           # Min folders before partitioning fires
MAIL_PARTITION_MIN_BYTES=             # Min total bytes before partitioning fires
MAIL_PARTITION_MAX_SHARDS=            # Hard cap on shard count
MAIL_PARTITION_TARGET_BYTES_PER_SHARD= # Target shard size; binpacker tries to hit this

# Chats partition (USER_CHATS)
CHATS_PARTITION_ENABLED=
CHATS_PARTITION_MIN_CHATS=            # Min chats before partitioning fires
CHATS_PARTITION_MAX_SHARDS=
CHATS_PARTITION_TARGET_CHATS_PER_SHARD=

# OneDrive partition (USER_ONEDRIVE)
ONEDRIVE_PARTITION_ENABLED=
ONEDRIVE_PARTITION_MIN_FILES=
ONEDRIVE_PARTITION_MIN_BYTES=
ONEDRIVE_PARTITION_MAX_SHARDS=
ONEDRIVE_PARTITION_TARGET_BYTES_PER_SHARD=

# SharePoint partition (SHAREPOINT_SITE)
SP_PARTITION_ENABLED=
SP_PARTITION_MIN_DRIVES=
SP_PARTITION_MIN_BYTES=
SP_PARTITION_MAX_SHARDS=
SP_PARTITION_TARGET_BYTES_PER_SHARD=

# Groups partition (GROUP_TEAM / channels)
GROUPS_PARTITION_ENABLED=
GROUPS_PARTITION_MIN_CHANNELS=
GROUPS_PARTITION_MAX_SHARDS=
GROUPS_PARTITION_CHANNELS_PER_SHARD=

# Entra partition (directory categories)
ENTRA_PARTITION_ENABLED=
ENTRA_PARTITION_MIN_CATEGORIES=
ENTRA_PARTITION_MAX_SHARDS=
ENTRA_PARTITION_CATEGORIES_PER_SHARD=

# ═══════════════════════════════════════════════════════════════════════
# USER_CONTACT backup (newer knobs)
# ═══════════════════════════════════════════════════════════════════════
BACKUP_CONTACTS_INCLUDE_DELETED=      # Include soft-deleted contacts
BACKUP_CONTACTS_INCLUDE_RECOVERABLE=  # Include items in the "Recoverable Items" container

# ═══════════════════════════════════════════════════════════════════════
# Calendar backup (newer knobs)
# ═══════════════════════════════════════════════════════════════════════
CALENDAR_SUBCALENDAR_REFRESH_HOURS=   # Throttle: refresh per-sub-calendar metadata at most this often (default 24h)

# ═══════════════════════════════════════════════════════════════════════
# USER_CHATS — newer knobs (2026-05-17 chat perf + interleave)
# ═══════════════════════════════════════════════════════════════════════
USER_CHATS_HC_BARRIER_DETACHED=       # Don't block handler return on HC drain (handler returns; HC finishes in background → snapshots.hc_drain_status)
USER_CHATS_INTERLEAVE_ATTACHMENTS=    # Run phase-2 attachment fetches in parallel with the chat drain (saves wall time)
USER_CHATS_INTERLEAVE_ATTACHMENT_CONCURRENCY= # Concurrency for the interleaved attachment fetches
USER_CHATS_CANCEL_CHECK_EVERY_CHATS=  # Cancel-poll cadence (every N chats inside a per-user drain)
USER_CHATS_DEBUG_MEMBERS=             # Paired with USER_CHATS_DEBUG_USER; ';'-separated emails/names to search for in members
CHAT_DRAIN_COMPLETENESS_DROP_PCT=     # Treat a drain as partial (don't advance cursor) if msg count drops >= this % vs prior baseline

# ═══════════════════════════════════════════════════════════════════════
# Chat export — newer knobs
# ═══════════════════════════════════════════════════════════════════════
CHAT_EXPORT_DYNAMIC_PREFETCH=         # Adaptive RMQ prefetch on export consumers
CHAT_EXPORT_PROGRESS_TRANSPORT=       # `db` | `redis` | `both` — where progress events flow

# ═══════════════════════════════════════════════════════════════════════
# OneDrive — newer big-file + flush knobs
# ═══════════════════════════════════════════════════════════════════════
ONEDRIVE_PREFETCH_CONCURRENCY=        # Cross-tenant RMQ prefetch dedicated to OneDrive (default 16)
ONEDRIVE_FLUSH_BACKLOG_CAP=           # Max queued flushes before back-pressure on the streaming writer
ONEDRIVE_LARGE_FILE_THRESHOLD_BYTES=  # Bytes above which the large-file path engages
ONEDRIVE_LARGE_FILE_SEGMENT_BYTES=    # Segment size for large-file chunked upload
ONEDRIVE_LARGE_FILE_SEGMENT_CONCURRENCY= # Concurrent segments per large file
ONEDRIVE_HUGE_FILE_RAM_BUDGET_GIB=    # Hard RAM cap for the huge-file (>100 GB) path
ONEDRIVE_RESTORE_STREAMING_THRESHOLD_BYTES= # Restore: switch to streaming above this size

# ═══════════════════════════════════════════════════════════════════════
# Heavy export sizing
# ═══════════════════════════════════════════════════════════════════════
HEAVY_EXPORT_THRESHOLD_BYTES=         # Exports above this route to the heavy queue

# ═══════════════════════════════════════════════════════════════════════
# RabbitMQ management
# ═══════════════════════════════════════════════════════════════════════
RABBITMQ_MGMT_URL=                    # Management API URL (autoscaler / capacity)

# ═══════════════════════════════════════════════════════════════════════
# Workers / scheduler — newer knobs
# ═══════════════════════════════════════════════════════════════════════
BACKUP_WORKER_DEDICATED_ONLY=         # Worker consumes only its dedicated queue (no shared fallback)
BATCH_ROW_REDESIGN_ENABLED=           # Toggle for the new batch_rows table layout
