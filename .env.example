AUTH_SERVICE_URL=
TENANT_SERVICE_URL=
RESOURCE_SERVICE_URL=
JOB_SERVICE_URL=
SNAPSHOT_SERVICE_URL=
BACKUP_SCHEDULER_URL=
PROGRESS_TRACKER_URL=
DASHBOARD_SERVICE_URL=
AUDIT_SERVICE_URL=
ALERT_SERVICE_URL=
REPORT_SERVICE_URL=
RAILWAY_SERVICE_API_GATEWAY_URL=      # Internal Railway DNS for the gateway

# ═══════════════════════════════════════════════════════════════════════
# Backup scheduler / dispatch
# ═══════════════════════════════════════════════════════════════════════
BACKUP_CONCURRENCY=                   # Workers per tenant
BACKUP_GROUP_TIMEOUT_S=                # Per-resource-group hard ceiling
BACKUP_FANOUT_PUBLISH_CHUNK=          # Items per RMQ publish chunk on fanout
BACKUP_VERIFY_LOOKBACK_HOURS=         # Backup-verify window
BACKUP_VERIFY_SAMPLE_SIZE=            # Sample size for backup-verify

# Per-priority queue prefetch
BACKUP_URGENT_PREFETCH=
BACKUP_HIGH_PREFETCH=
BACKUP_NORMAL_PREFETCH=
BACKUP_LOW_PREFETCH=
BACKUP_MAIL_PARTITION_PREFETCH=
BACKUP_CHATS_PARTITION_PREFETCH=
BACKUP_GROUPS_PARTITION_PREFETCH=
BACKUP_ENTRA_PARTITION_PREFETCH=
BACKUP_SP_PARTITION_PREFETCH=

# Cross-job duplicate guard (2026-05-18). When true (default) the per-
# resource handler refuses to run if a recent IN_PROGRESS snapshot for
# the same resource exists under a *different* job_id — prevents two
# concurrent jobs (e.g. instant-run on top of scheduled) from racing
# the same Graph delta cursor.
BACKUP_SKIP_CONCURRENT_JOBS=

# Heavy / partitioned queues
BACKUP_HEAVY_ENABLED=
BACKUP_HEAVY_THRESHOLD_BYTES=         # Bytes above which work routes to heavy queue
BACKUP_HEAVY_QUEUE=
BACKUP_WORKER_QUEUE=                  # Default worker queue name
HEAVY_EXPORT_ENABLED=
HEAVY_EXPORT_QUEUE=
HEAVY_RESTORE_THRESHOLD_BYTES=
RESTORE_WORKER_QUEUE=

# Retry / backoff
MAX_RETRIES=
RETRY_BACKOFF_MULTIPLIER=
RETRY_DELAY_MS=
PARTITION_MAX_RETRIES=
BATCH_STALL_TIMEOUT_HOURS=            # Batch considered stalled past this

# Worker generic
WORKER_REGION=                        # Region tag (used for affinity)
WORKER_RESTART_STRATEGY=
WORKLOAD_CONCURRENCY=                 # Per-worker simultaneous workloads
RESOURCE_CHUNK_SIZE=                  # Page size on Resource scans

# ═══════════════════════════════════════════════════════════════════════
# Discovery
# ═══════════════════════════════════════════════════════════════════════
DISCOVERY_DEADLINE_MIN=               # Hard cap on a discovery run
DISCOVERY_PROGRESS_LOG_EVERY=         # Log emission cadence (resources)
DISCOVERY_STAGE_CHUNK_SIZE=           # Per-stage commit batch
TIER2_DISCOVERY_BACKSTOP_S=           # Backstop timer for tier-2 discovery

# ═══════════════════════════════════════════════════════════════════════
# USER_MAIL backup
# ═══════════════════════════════════════════════════════════════════════
USER_MAIL_PARALLEL_FOLDERS=           # Concurrent folder drains per user
USER_MAIL_TIMEOUT_S=                  # Per-user mail handler hard ceiling
USER_MAIL_FULL_RESCAN_DAYS=           # Force full rescan if baseline older
USER_MAIL_ATT_BATCH=                  # Attachments per Graph batch
USER_MAIL_ATT_CONCURRENCY=            # Concurrent attachment fetches
USER_MAIL_UPLOAD_CONCURRENCY=         # Blob upload concurrency for mail
MAILBOX_PARALLEL_FOLDERS=             # Legacy alias for folder concurrency
MAILBOX_TIMEOUT_S=                    # Legacy alias for handler ceiling
INLINE_ATTACHMENT_MAX_BYTES=          # Cap on inline-stored attachment size

# Mail restore
MAIL_RESTORE_V2_ENABLED=
MAIL_RESTORE_GLOBAL_POOL=             # Global parallel restore cap
MAIL_RESTORE_PER_MAILBOX=             # Per-mailbox parallel cap
MAIL_RESTORE_MAX_RETRIES=
MAIL_RESTORE_ATTACH_LARGE_MB=         # Switch to multipart/upload above this

# ═══════════════════════════════════════════════════════════════════════
# USER_CHATS backup
# ═══════════════════════════════════════════════════════════════════════
USER_CHATS_PARALLEL_CHATS=            # Concurrent per-chat drains per user
USER_CHATS_TIMEOUT_S=                 # Per-user chats handler hard ceiling
USER_CHATS_APP_SHARDS=                # Multi-app sharding (0 = all healthy apps)
USER_CHATS_FULL_RESCAN_DAYS=          # Skip-by-activity baseline expiry
USER_CHATS_ATTACHMENT_CONCURRENCY=    # Phase-2 chat attachment fetches
USER_CHATS_INTERLEAVE_HOSTED_CONTENT= # Inline-image fetch during drain (faster)

# Per-chat hostedContent (inline images)
CHAT_HOSTED_CONTENT_CONCURRENCY=
CHAT_HOSTED_CONTENT_MAX_BYTES=        # Cap on single hostedContent
CHAT_HC_DOWNLOAD_CONCURRENCY=
CHAT_HC_UPLOAD_CONCURRENCY=
CHAT_HC_MSG_CONCURRENCY=

# Chat thread drain
CHAT_THREAD_DRAIN_FRESHNESS_S=        # Skip per-chat drain if recent enough
CHAT_DRAIN_RETRIES=
CHAT_URL_CACHE_TTL_DAYS=
CHAT_INTEGRITY_INTERVAL_S=            # Integrity sweep cadence
CHAT_INTEGRITY_TOLERANCE_PCT=         # Drop% before integrity sweep alerts

# Diagnostics (USER_CHATS chat-name diagnosis — 2026-05-18)
# When set to a userId or resourceId, the next backup of that user prints
# a discovery dump (chats_raw count, chatType breakdown, unresolved-name
# count, and member-search results) once. Zero cost when unset.
USER_CHATS_DEBUG_USER=
# Optional, paired with the above: semicolon list of emails/names to
# search for in any chat's members. E.g. "rashmi.mishra@…;akshat.verma@…".
# USER_CHATS_DEBUG_MEMBERS=

# Chat export
CHAT_EXPORT_DEFAULT_ENABLED=
CHAT_EXPORT_BLOB_ACCOUNTS=            # Comma list of account names for export staging
CHAT_EXPORT_BLOB_ACCOUNT_SHARDS=      # Shard count per account
CHAT_EXPORT_BLOB_TTL_HOURS=
CHAT_EXPORT_SAS_TTL_HOURS=            # SAS URL TTL
CHAT_EXPORT_HOT_TIER_HOURS=           # Hot-tier retention window
CHAT_EXPORT_SIZE_SOFT_CAP_BYTES=
CHAT_EXPORT_SIZE_HARD_CAP_BYTES=
CHAT_EXPORT_TENANT_CONCURRENT_MIN=
CHAT_EXPORT_TENANT_CONCURRENT_PER_USER=

