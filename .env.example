# TM Vault Backend Configuration — full reference.
# Copy this file to `.env` and fill in values for your environment.
# Every variable used anywhere in the backend is listed here; many have
# sensible defaults inside the code and only need to be set in
# production or to override behaviour. Production deploys also use the
# same names in Railway env (see deploy/taylor-morrison/.env.template).
#
# Convention: leave blank to use the in-code default, set explicitly to
# override. Booleans accept true/false/1/0/yes/no.

# ═══════════════════════════════════════════════════════════════════════
# Server / Network
# ═══════════════════════════════════════════════════════════════════════
SERVER_PORT=                          # HTTP port for the gateway/service (default 8000)
HOSTNAME=                             # OS hostname, auto-set; rarely overridden
FRONTEND_URL=                         # Public URL of the React SPA (used in OAuth callbacks, emails)
API_GATEWAY_PUBLIC_URL=               # Public URL of the API gateway (used by external webhooks)
CORS_ORIGINS=                         # JSON list of allowed origins, e.g. ["http://localhost:3000"]
CORS_ALLOWED_ORIGINS=                 # Alternate spelling honoured for back-compat
COOKIE_DOMAIN=                        # Domain for auth cookies (e.g. .tmvault.example)
COOKIE_SAMESITE=                      # SameSite policy: Lax | Strict | None
COOKIE_SECURE=                        # Require HTTPS cookies (true in prod, false in local dev)
INTERNAL_API_KEY=                     # Shared secret for service-to-service calls behind the gateway

# ═══════════════════════════════════════════════════════════════════════
# Database (Postgres)
# ═══════════════════════════════════════════════════════════════════════
DATABASE_URL=                         # Full DSN; if set, takes precedence over DB_HOST/PORT/USER/PASSWORD/NAME
DB_HOST=                              # Postgres hostname
DB_PORT=                              # Postgres port
DB_NAME=                              # Database name
DB_USER=                              # Username (preferred)
DB_USERNAME=                          # Alias for DB_USER (back-compat)
DB_PASSWORD=                          # Password
DB_SCHEMA=                            # Schema name (defaults to public)
DB_POOL_SIZE=                         # SQLAlchemy pool size per process
DB_MAX_OVERFLOW=                      # Pool overflow allowance
DB_POOL_TIMEOUT=                      # Seconds to wait for a connection before erroring
DB_POOL_RECYCLE=                      # Seconds before recycling idle connections
DB_POOL_USE_LIFO=                     # LIFO connection reuse (true reduces idle conns)
STATEMENT_CACHE_SIZE=                 # asyncpg per-conn prepared-statement cache size

# DR / failover
DR_PG_DSN=                            # DSN of the DR replica Postgres
DR_CHAT_REPL_INTERVAL_S=              # Cadence of chat replication probe
PATRONI_TARGET_URL=                   # Patroni REST URL when using Patroni-based PG HA
PG_PROMOTE_STRATEGY=                  # `patroni` | `dns_flip` | `manual`
DNS_FLIP_SCRIPT=                      # Shell script invoked on DNS-flip strategy
DNS_FLIP_STRATEGY=                    # `route53` | `cloudflare` | `script`
LAST_PG_DUMP_PATH=                    # Path of last pg_dump (used by backup verifier)

# ═══════════════════════════════════════════════════════════════════════
# Auth / JWT
# ═══════════════════════════════════════════════════════════════════════
JWT_SECRET=                           # Default JWT signing secret (used if access/refresh secrets unset)
ACCESS_TOKEN_SECRET=                  # Distinct access-token signing secret (defense in depth)
REFRESH_TOKEN_SECRET=                 # Distinct refresh-token signing secret
JWT_EXPIRATION_HOURS=                 # Access token TTL in hours
JWT_REFRESH_EXPIRATION_DAYS=          # Refresh token TTL in days
ENCRYPTION_KEY=                       # Fernet key for at-rest secret encryption (cryptography.fernet.Fernet)

# ═══════════════════════════════════════════════════════════════════════
# Microsoft Graph — OAuth + Application Permissions
# ═══════════════════════════════════════════════════════════════════════
# Required Graph permissions (admin-consented):
#   Directory.Read.All, User.Read.All, Group.Read.All, Mail.Read,
#   Files.Read.All, Sites.Read.All, ChannelMessage.Read.All,
#   Chat.Read.All, Contacts.Read, Calendars.Read, Notes.Read.All,
#   Tasks.Read.All, Application.Read.All, Policy.Read.All
MICROSOFT_CLIENT_ID=                  # Primary multi-tenant app client id
MICROSOFT_CLIENT_SECRET=              # Primary app client secret
MICROSOFT_TENANT_ID=                  # Tenant id, or `common` for multi-tenant
MICROSOFT_AUTH_URL=                   # Override OAuth authorize URL (rarely needed)
MICROSOFT_TOKEN_URL=                  # Override OAuth token URL
DATASOURCE_AUTH_URL=                  # Alias used by the datasource service
DATASOURCE_TOKEN_URL=                 # Alias used by the datasource service
DELTA_TOKEN_URL=                      # Per-tenant delta-token issuer (where applicable)

# Azure AD (sign-in to the app)
AZURE_AD_CLIENT_ID=                   # Same as MICROSOFT_CLIENT_ID when collapsed
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Multi-app registration pool (mass backup distributes load across apps).
# Loader accepts APP_1_* through APP_20_*.  Each app gets its own Graph
# rate-limit budget — more apps = more throughput.
APP_1_CLIENT_ID=
APP_1_CLIENT_SECRET=
APP_1_TENANT_ID=
# APP_2_CLIENT_ID=
# APP_2_CLIENT_SECRET=
# APP_2_TENANT_ID=
# … up to APP_20_*

# ═══════════════════════════════════════════════════════════════════════
# Microsoft Graph — Throttle hardening (shared/graph_client.py)
# ═══════════════════════════════════════════════════════════════════════
GRAPH_HARDENING_ENABLED=              # Master flag for the policy-driven path
GRAPH_APP_PACE_REQS_PER_SEC=          # Per-app token-bucket fill rate
GRAPH_STREAM_PACE_REQS_PER_SEC=       # Per-stream pace cap (e.g. mail/messages)
GRAPH_PRIORITY_SCHEDULING_ENABLED=    # HIGH/URGENT skip ahead of NORMAL on contended buckets
GRAPH_MAX_RETRIES=                    # Max retries per request
GRAPH_THROTTLE_BACKOFF_SECONDS=       # 429-specific backoff ladder (comma list)
GRAPH_TRANSIENT_BACKOFF_SECONDS=      # 5xx / timeout backoff ladder
GRAPH_JITTER_RATIO=                   # Random jitter applied to backoff
GRAPH_POST_THROTTLE_BRAKE_MS=         # Post-recovery brake after a 429
GRAPH_MAX_CUMULATIVE_WAIT_SECONDS=    # Hard cap on cumulative wait per request
GRAPH_MAX_THROTTLE_WAIT_SECONDS=      # Hard cap on a single 429 wait
GRAPH_STICKY_PAGES_BEFORE_RETURN=     # Pages stayed on one app before round-robin
GRAPH_BATCH_MAX_SIZE=                 # Max requests per $batch
GRAPH_BATCH_SIZE=                     # Default batch size (legacy alias)
GRAPH_APP_MAX=                        # Hard cap on apps used per backup run
GRAPH_RATE_LIMITER_ENABLED=           # Enable the global Graph rate limiter
GRAPH_GLOBAL_RPS=                     # Tenant-wide ceiling RPS
GRAPH_GLOBAL_BURST=                   # Tenant-wide burst budget
GRAPH_PROXY_URL=                      # Optional egress proxy for Graph calls
GRAPHCLIENT_HTTP2=                    # Enable HTTP/2 for Graph client (httpx)

# Adaptive circuit-breaker (per-app)
GRAPH_APP_429_THRESHOLD=              # 429s in window to enter probation
GRAPH_APP_429_WINDOW_S=               # Probation window length
GRAPH_APP_BAN_LADDER=                 # Comma ladder of ban durations
GRAPH_APP_PROBATION_OK=               # Successes to exit probation
GRAPH_APP_RATE_DEC=                   # Per-throttle rate decrement
GRAPH_APP_RATE_INC=                   # Per-success rate increment
GRAPH_APP_RATE_FLOOR=                 # Floor RPS during probation
GRAPH_APP_RATE_RECOVER_S=             # Recovery interval to step rate back up
GRAPH_APP_RESET_AFTER_OK=             # Clean runs before full reset

# ═══════════════════════════════════════════════════════════════════════
# Azure Storage (snapshot blobs)
# ═══════════════════════════════════════════════════════════════════════
AZURE_STORAGE_ACCOUNT_NAME=           # Primary storage account
AZURE_STORAGE_ACCOUNT_KEY=            # Account key (consider managed identity instead)
AZURE_STORAGE_BLOB_ENDPOINT=          # Override blob endpoint (sovereign clouds)
AZURE_UPLOAD_CONCURRENCY=             # Per-upload concurrency
AZURE_BLOCK_SIZE_MB=                  # BlockBlob block size
COPY_CONCURRENCY=                     # Server-side copy concurrency (Azure → Azure)
SERVER_SIDE_COPY_THRESHOLD=           # Bytes threshold above which to use server-side copy

# Storage routing / shard fabric
ACTIVE_STORAGE_BACKEND=               # Override the runtime backend selection
STORAGE_DEFAULT_BACKEND=              # Default backend id when no shard match
STORAGE_FACADE_LOG_FALLBACKS=         # Log when facade falls back to default
STORAGE_ROUTER_STRICT=                # Fail loudly on routing mismatches
STORAGE_ROUTER_MAX_RETRIES=
STORAGE_ROUTER_BACKOFF_BASE_S=
STORAGE_ROUTER_BACKOFF_CAP_S=
STORAGE_BOOTSTRAP_LOCK_DEADLINE_S=    # Bootstrap election deadline
STORAGE_BUCKET_ENSURE_ATTEMPTS=       # Retries for bucket creation
STORAGE_BUCKET_ENSURE_BACKOFF_S=
STORAGE_SHARD_COUNT=                  # Number of shard accounts
STORAGE_SHARD_ACCOUNTS=               # Comma list of shard account names
STORAGE_SHARD_KEYS=                   # Comma list of shard keys (parallel to accounts)
ROUTING_FENCE_ENABLED=                # Hard fence between shards
ROUTING_MAX_HOPS=                     # Max hops before routing gives up

# Blob dedup
BLOB_DEDUP_BULK_CHUNK=                # Rows per dedup probe batch
BLOB_DEDUP_LRU_MAX_ENTRIES=           # In-process LRU size
BLOB_DEDUP_LRU_HIT_TTL_S=             # TTL for positive cache entries
BLOB_DEDUP_LRU_MISS_TTL_S=            # TTL for negative cache entries
BLOB_DEDUP_MIN_SIZE_BYTES=            # Below this, skip dedup (overhead > savings)

# ═══════════════════════════════════════════════════════════════════════
# Azure ARM (Power BI restore-point / Azure VM workloads)
# ═══════════════════════════════════════════════════════════════════════
AZURE_ARM_CLIENT_ID=
AZURE_ARM_CLIENT_SECRET=
AZURE_ARM_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_BACKUP_REGION=                  # Azure region for backup ops
AZURE_BACKUP_RESOURCE_GROUP=          # Resource group for backup artefacts

# ═══════════════════════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════════════════════
REDIS_ENABLED=
REDIS_URL=                            # Full URL form; preferred if set
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=                             # Database index

# ═══════════════════════════════════════════════════════════════════════
