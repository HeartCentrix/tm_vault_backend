RABBITMQ_ENABLED=
RABBITMQ_URL=                         # Full AMQP URL form
AMQP_URL=                             # Alias for RABBITMQ_URL
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_USERNAME=                    # Alias for RABBITMQ_USER
RABBITMQ_PASSWORD=
RABBITMQ_CONSUMER_HEARTBEAT_SECONDS=  # Connection heartbeat (long for long drains)
RABBITMQ_CONSUMER_TIMEOUT_MS=         # Consumer ack deadline (long for long drains)
RABBITMQ_MGMT_USER=                   # Management API auth (autoscaler uses it)
RABBITMQ_MGMT_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
